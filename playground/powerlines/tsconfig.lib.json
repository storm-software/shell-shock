{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "out-tsc/tsconfig.tsbuildinfo",
    "jsx": "preserve",
    "types": ["node"],
    "outDir": "./out-tsc"
  },
  "references": [
    {
      "path": "../../packages/plugin-theme/tsconfig.lib.json"
    },
    {
      "path": "../../packages/preset-script/tsconfig.lib.json"
    },
    {
      "path": "../../packages/core/tsconfig.lib.json"
    }
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "powerlines.config.ts",
    "powerlines.d.ts"
  ],
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts"]
}
