    "./types/plugin": {
      "require": {
        "types": "./dist/types/plugin.d.cts",
        "default": "./dist/types/plugin.cjs"
      },
      "import": {
        "types": "./dist/types/plugin.d.mts",
        "default": "./dist/types/plugin.mjs"
      },
      "default": {
        "types": "./dist/types/plugin.d.mts",
        "default": "./dist/types/plugin.mjs"
      }
    }
